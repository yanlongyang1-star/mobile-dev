# Copy to .env in this folder (my-app). Never commit .env — it is gitignored.
# Values: Firebase Console → Project settings → Your apps → Web app → firebaseConfig.
# Also enable Authentication → Email/Password, create a Firestore database, and enable Cloud Storage.
# Paste Firestore rules from docs/firebase-firestore-rules.example
# Paste Storage rules from docs/firebase-storage-rules.example
# Then restart: npx expo start --clear

FIREBASE_API_KEY=replace_me
FIREBASE_AUTH_DOMAIN=replace_me.firebaseapp.com
FIREBASE_PROJECT_ID=replace_me
FIREBASE_STORAGE_BUCKET=replace_me.appspot.com
FIREBASE_MESSAGING_SENDER_ID=replace_me
FIREBASE_APP_ID=replace_me
ALLOWED_UNI_DOMAINS=students.latrobe.edu.au,latrobe.edu.au

# Google sample AdMob IDs are safe for development. Replace with real IDs before release.
ADMOB_ANDROID_APP_ID=ca-app-pub-3940256099942544~3347511713
ADMOB_IOS_APP_ID=ca-app-pub-3940256099942544~1458002511
ADMOB_BANNER_UNIT_ID=ca-app-pub-3940256099942544/6300978111
